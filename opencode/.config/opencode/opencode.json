{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "jq *": "allow",
      "grep *": "allow",
      "awk *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "echo *": "allow",
      "git log *": "allow",
      "git find *": "allow",
      "git status *": "allow",
    }
  },
  "mcp": {
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp",
      "enabled": true
    }
  },
  "tools": {
    "svelte": false
  }
}
